# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://osf_user:osf_pass@postgres:5432/osf
DATABASE_URL_SYNC=postgresql://osf_user:osf_pass@postgres:5432/osf

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ─── External APIs ────────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here
# POLYGON_API_KEY=your_polygon_key_here   # Phase 3+ only

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=info
